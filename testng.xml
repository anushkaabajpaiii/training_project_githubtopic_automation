<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="GitHubAnalyticsSuite" verbose="1" parallel="tests" thread-count="4">

    <listeners>
        <listener class-name="com.automation.listeners.TestListener"/>
        <listener class-name="com.automation.listeners.RetryListener"/>
    </listeners>

    <test name="GitHubSearch_Chrome">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="com.automation.tests.GitHubSearchTest"/>
        </classes>
    </test>

    <test name="RepositoryAnalytics_Chrome">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="com.automation.tests.RepositoryAnalyticsTest"/>
        </classes>
    </test>

    <test name="ParallelAnalytics_Java_Python_Selenium_Automation" parallel="methods" thread-count="4">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="com.automation.tests.ParallelAnalyticsTest"/>
        </classes>
    </test>

</suite>
