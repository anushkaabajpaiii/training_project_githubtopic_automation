<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="GitHubAnalyticsCrossBrowserSuite" verbose="1" parallel="tests" thread-count="3">

    <listeners>
        <listener class-name="com.automation.listeners.TestListener"/>
        <listener class-name="com.automation.listeners.RetryListener"/>
    </listeners>

    <test name="GitHubSearch_Chrome">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="com.automation.tests.GitHubSearchTest"/>
        </classes>
    </test>

    <test name="GitHubSearch_Firefox">
        <parameter name="browser" value="firefox"/>
        <classes>
            <class name="com.automation.tests.GitHubSearchTest"/>
        </classes>
    </test>

    <test name="GitHubSearch_Edge">
        <parameter name="browser" value="edge"/>
        <classes>
            <class name="com.automation.tests.GitHubSearchTest"/>
        </classes>
    </test>

</suite>
